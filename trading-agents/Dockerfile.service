FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source code
COPY src/ ./src/

# Expose port
EXPOSE 8000

# Default command
CMD ["python", "-m", "uvicorn", "src.services.data_service:app", "--host", "0.0.0.0", "--port", "8000"]
